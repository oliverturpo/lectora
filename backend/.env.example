# Django Settings
DEBUG=True
SECRET_KEY=your-secret-key-here-change-in-production
ALLOWED_HOSTS=localhost,127.0.0.1

# Database Configuration
DB_NAME=asistencia_db
DB_USER=postgres
DB_PASSWORD=your_password_here
DB_HOST=localhost
DB_PORT=5432

# CORS (Frontend URLs)
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# JWT Settings
JWT_ACCESS_TOKEN_LIFETIME_HOURS=24
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7

# Horarios del Sistema (formato HH:MM)
ATTENDANCE_OPEN_TIME=07:30
ATTENDANCE_PUNCTUALITY_LIMIT=07:45
ATTENDANCE_CLOSE_TIME=08:00

# Información de la Institución
INSTITUTION_NAME=IES Túpac Amaru
INSTITUTION_WEBSITE=www.iestupacamaru.edu.pe

# Días laborables (separados por coma)
WORKING_DAYS=monday,tuesday,wednesday,thursday,friday
